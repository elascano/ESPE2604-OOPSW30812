import json
from goalkeeper import Goalkeeper

goalkeepers = []

goalkeepers.append(Goalkeeper(1, "Manuel Neuer", 38, "Bayern Munich"))
goalkeepers.append(Goalkeeper(2, "Alisson Becker", 32, "Liverpool"))
goalkeepers.append(Goalkeeper(3, "Thibaut Courtois", 33, "Real Madrid"))

def save_to_json():
    data = []

    for goalkeeper in goalkeepers:
        data.append(goalkeeper.to_dict())

    with open("goalkeepers.json", "w") as file:
        json.dump(data, file, indent=4)

    print("Data saved to JSON file.")

def read_from_json():

    with open("goalkeepers.json", "r") as file:
        data = json.load(file)

    print("\nReading data from JSON file:\n")

    for goalkeeper in data:
        print(
            f"ID: {goalkeeper['id']}, "
            f"Name: {goalkeeper['name']}, "
            f"Age: {goalkeeper['age']}, "
            f"Team: {goalkeeper['team']}"
        )


# Main program
save_to_json()
read_from_json()
