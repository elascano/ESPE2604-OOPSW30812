body {

    font-family: Arial, sans-serif;
    background-color: #f2f2f2;

    margin: 40px;
}

.container {

    width: 700px;

    background: white;

    padding: 20px;

    border-radius: 10px;

    box-shadow: 0px 0px 10px gray;
}

input {

    width: 250px;

    padding: 8px;

    margin: 5px;
}

button {

    padding: 10px;

    margin: 5px;

    cursor: pointer;
}

#result {

    margin-top: 20px;

    padding: 15px;

    border: 1px solid gray;

    min-height: 150px;
}